{
    "apiVersion": 3,
    "name": "mpe2025/custom-post-grid",
    "version": "1.0.0",
    "title": "Custom Post Grid",
    "category": "widgets",
    "icon": "grid-view",
    "description": "Display a grid of posts, services, vehicles, or excursions.",
    "supports": {
        "html": false
    },
    "attributes": {
        "postType": {
            "type": "string",
            "default": "post"
        },
        "selectedCategory": {
            "type": "string",
            "default": ""
        },
        "postsToShow": {
            "type": "number",
            "default": 3
        }
    },
    "textdomain": "mpe2025",
    "editorScript": "file:./index.js",
    "render": "file:./render.php"
}
